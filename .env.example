NODE_ENV=development
PORT=4000

# JWTs — secrets MUST match core-service so cross-issued tokens verify
ACCESS_SECRET=changeme
REFRESH_SECRET=changeme
ACCESS_EXPIRES_IN=3600
REFRESH_EXPIRES_IN=604800

CORS_ORIGINS=http://localhost:3000

# Region sharding
REGIONS=eg,ksa
DB_POOL_MAX=10
DB_MIGRATION_DIRECTORY=src/database/migrations
DB_MIGRATION_EXTENSION=ts

# Hot DB clusters — one block per region listed in REGIONS
DB_eg_HOST=localhost
DB_eg_PORT=5432
DB_eg_USERNAME=postgres
DB_eg_PASSWORD=postgres
DB_eg_NAME=order_service_eg
DB_ksa_HOST=localhost
DB_ksa_PORT=5432
DB_ksa_USERNAME=postgres
DB_ksa_PASSWORD=postgres
DB_ksa_NAME=order_service_ksa

# Archive (cold) DB clusters — same shape, separate hosts; consumed in Phase 7
ARCHIVE_DB_eg_HOST=localhost
ARCHIVE_DB_eg_PORT=5432
ARCHIVE_DB_eg_USERNAME=postgres
ARCHIVE_DB_eg_PASSWORD=postgres
ARCHIVE_DB_eg_NAME=order_service_archive_eg
ARCHIVE_DB_ksa_HOST=localhost
ARCHIVE_DB_ksa_PORT=5432
ARCHIVE_DB_ksa_USERNAME=postgres
ARCHIVE_DB_ksa_PASSWORD=postgres
ARCHIVE_DB_ksa_NAME=order_service_archive_ksa

# Redis (cache + presence + ws redis-adapter pubsub + idempotency)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ (inbound core events)
RABBITMQ_URL=amqp://order-service:secret@localhost:5672/quickbite
RABBITMQ_CORE_EVENTS_EXCHANGE=core.events
RABBITMQ_CORE_EVENTS_AE=core.events.unroutable
RABBITMQ_CORE_EVENTS_UNROUTABLE_QUEUE=core.events.unroutable.dlq
RABBITMQ_CORE_EVENTS_QUEUE=order-service.core-events
RABBITMQ_CORE_EVENTS_BINDINGS="product.#,branch.#,restaurant.#,rbac.#"
RABBITMQ_CORE_EVENTS_DLX=core.events.dlx
RABBITMQ_CORE_EVENTS_DLQ=order-service.core-events.dlq
RABBITMQ_PREFETCH=32

# core-service integration
CORE_SERVICE_BASE_URL=http://localhost:3000
CORE_INTERNAL_API_KEY=changeme

# Kashier (Phase 2). Use test-* hosts in dev/staging.
KASHIER_BASE_URL=https://test-api.kashier.io
KASHIER_FEP_URL=https://test-fep.kashier.io
KASHIER_MERCHANT_ID=MID-XXXXX-XXX
KASHIER_API_KEY=                  # Payment API Key (api-key header + hash + webhook signature)
KASHIER_SECRET_KEY=               # Secret Key (Authorization header)
KASHIER_WEBHOOK_SECRET=           # Optional override; defaults to KASHIER_API_KEY
KASHIER_RETURN_URL=http://localhost:3000/checkout/return
KASHIER_FAIL_URL=http://localhost:3000/checkout/failed
# Set to your public webhook URL (e.g. ngrok) so Kashier can POST events back.
KASHIER_SERVER_WEBHOOK=
PAYMENT_SESSION_TIMEOUT_MIN=15

# Deliveries / assignment (Phase 3+)
ASSIGNMENT_RADIUS_METERS=5000
ASSIGNMENT_CANDIDATE_K=5
AGENT_ACCEPT_TIMEOUT_SEC=30
MAX_REASSIGNMENT_ATTEMPTS=3
# Strict 5-minute cutoff for last-seen ping (per agreed design).
PRESENCE_STALE_SEC=300
# Share of branch.deliveryFee paid to the agent on `delivered` (0..1).
AGENT_SHARE_RATE=1

# WebSocket
WS_HEARTBEAT_SEC=30

# Archival worker (Phase 6) — nightly cold-storage move.
# Hard cap on one run; leftover rows are picked up the following night.
ARCHIVAL_MAX_RUNTIME_MIN=60
